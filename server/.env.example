# --- Server ---
PORT=4000
# Comma-separated list of allowed dashboard origins for CORS (use * for any in dev)
CORS_ORIGIN=http://localhost:4200

# --- Dashboard access token (REQUIRED) ---
# Single shared secret gating all read/admin endpoints and the WebSocket. If this
# is empty the API fails CLOSED (those routes return 503) so a deploy is never
# accidentally left open to the internet. Generate a strong one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Then enter the same value in the dashboard when it prompts for a token.
DASHBOARD_TOKEN=

# --- Database ---
# Either provide DATABASE_URL, or the discrete PG* vars below.
DATABASE_URL=postgres://telemetry:telemetry@localhost:5432/telemetry
PGHOST=localhost
PGPORT=5432
PGUSER=telemetry
PGPASSWORD=telemetry
PGDATABASE=telemetry
# Set to true when connecting to a managed Postgres that requires TLS
PGSSL=false

# --- Ingest rate limiting (per API key) ---
INGEST_RATE_WINDOW_MS=60000
INGEST_RATE_MAX=600

# --- Offline detection ---
# A resource is flagged offline if no datapoint arrived within
# interval_seconds * OFFLINE_INTERVAL_MULTIPLIER.
OFFLINE_INTERVAL_MULTIPLIER=3

# --- Retention (Phase 5) ---
# Keep raw compute_metrics for this many days, then downsample to hourly averages.
RETENTION_RAW_DAYS=7
RETENTION_HOURLY_DAYS=90
RETENTION_CRON=0 3 * * *

# --- API usage workers (Phase 3) ---
# Anthropic Admin/Usage API (workspace-level). Leave blank to disable the worker.
ANTHROPIC_ADMIN_KEY=
# Resource name the Anthropic worker writes to (auto-created if missing).
ANTHROPIC_RESOURCE_NAME=Claude API
ANTHROPIC_USAGE_CRON=0 * * * *

# Google Cloud billing export for Gemini. Leave blank to disable the worker.
GEMINI_BILLING_TABLE=
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_RESOURCE_NAME=Gemini API
GEMINI_BILLING_CRON=0 4 * * *
